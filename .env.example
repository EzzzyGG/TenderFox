# App
APP_NAME=TenderFox
ENV=local
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://tenderfox:tenderfox@postgres:5432/tenderfox

# Redis
REDIS_URL=redis://redis:6379/0

# External sources
GOSPLAN_BASE_URL=https://v2test.gosplan.info/fz44

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Scheduler
SCHEDULER_INTERVAL_SECONDS=300
SCHEDULER_STAGE=1
SCHEDULER_LIMIT_PER_SUB=20
SCHEDULER_MAX_MESSAGES_PER_CYCLE=30
SCHEDULER_SLEEP_BETWEEN_MESSAGES_MS=250
SCHEDULER_DRY_RUN=false
